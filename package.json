{
  "name": "doceomenter",
  "private": true,
  "version": "0.1.0",
  "description": "Turn a GitHub URL into a Markdown report, HTML deck, and PDF — with real screenshots and short videos of the project running.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/*' --filter './apps/*' run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "dev:web": "pnpm --filter @doceomenter/web dev",
    "dev:worker": "pnpm --filter @doceomenter/worker dev",
    "verify": "node scripts/verify.mjs"
  },
  "devDependencies": {
    "typescript": "5.6.3",
    "tsx": "4.19.2",
    "vitest": "2.1.4",
    "@types/node": "22.9.0"
  }
}
