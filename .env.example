# Anthropic. If unset and a request omits its own key, the run uses the
# deterministic fixture client (test mode).
ANTHROPIC_API_KEY=

# Models — override only if you know what you are doing.
ANTHROPIC_MODEL_PRIMARY=claude-opus-4-7
ANTHROPIC_MODEL_FALLBACK=claude-sonnet-4-6
ANTHROPIC_MODEL_CHEAP=claude-haiku-4-5-20251001

# Job queue.
REDIS_URL=redis://127.0.0.1:6379

# Storage. local | s3
STORAGE_DRIVER=local
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Package mirrors used by booted projects (egress allowlist in container mode).
NPM_REGISTRY=https://registry.npmjs.org
PIP_INDEX_URL=https://pypi.org/simple

# Resource caps.
MAX_REPO_MB=500
MAX_RUN_SECONDS=600

# Worker mode: in-process | container
# in-process runs the pipeline inside the worker (dev default).
# container spawns a Docker container per job (prod, requires docker daemon).
RUN_MODE=in-process

# Set to true only on a host with docker-in-docker properly configured.
ENABLE_DOCKER_IN_DOCKER=false

# Dev only. Public URL the web app exposes; the worker uses this to build
# fully-qualified asset URLs in artifacts.
PUBLIC_BASE_URL=http://localhost:3000

# Per-IP run quota for the public POST /api/runs endpoint.
RUN_RATE_LIMIT_PER_HOUR=3
